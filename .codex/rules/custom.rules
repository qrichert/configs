prefix_rule(pattern=["env", "GH_PAGER=", "gh", "issue", "view"], decision="allow")
prefix_rule(pattern=["env", "GH_PAGER=", "gh", "pr", "view"], decision="allow")

prefix_rule(pattern=["just", "makemigrations"], decision="allow")
prefix_rule(pattern=["just", "build"], decision="allow")
prefix_rule(pattern=["just", "test"], decision="allow")
prefix_rule(pattern=["just", "lint"], decision="allow")

prefix_rule(pattern=["uv", "run", "manage.py", "test"], decision="allow")
prefix_rule(pattern=["uv", "run", "ruff", "check"], decision="allow")
prefix_rule(pattern=["uv", "run", "ruff", "format"], decision="allow")
